# Ambiente — desenvolvimento, testnet ou produção
MDD_ENV=development

# Logging
MDD_LOG_LEVEL=INFO
MDD_LOG_JSON=false

# Exchange (a ser preenchida após Fase 1 — benchmark)
MDD_EXCHANGE=binance
MDD_EXCHANGE_TESTNET=true
MDD_API_KEY=
MDD_API_SECRET=
# REGRA DE SEGURANÇA: chave DEVE ter saque BLOQUEADO. Apenas leitura + trade.

# Banco de dados (TimescaleDB / PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mdd
POSTGRES_USER=mdd
POSTGRES_PASSWORD=change_me_in_local_only

# Prometheus / métricas
MDD_METRICS_PORT=9100

# Alertas — Telegram
MDD_TELEGRAM_BOT_TOKEN=
MDD_TELEGRAM_CHAT_ID=

# Risk Engine — limites iniciais conservadores (calibrar após backtest)
MDD_RISK_MAX_DAILY_DRAWDOWN_PCT=3.0
MDD_RISK_MAX_POSITION_PER_SIDE_PCT=30.0
MDD_RISK_LATENCY_P99_MS_LIMIT=500
MDD_RISK_INVENTORY_SKEW_LIMIT=0.5

# Capital alocado (apenas micro-prod inicialmente — USD)
MDD_CAPITAL_USD=500
